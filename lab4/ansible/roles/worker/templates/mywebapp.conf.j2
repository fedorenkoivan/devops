server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/mywebapp.access.log;
    error_log  /var/log/nginx/mywebapp.error.log;

    # Health endpoints are internal only — not exposed externally
    location = /health/alive { return 404; }
    location = /health/ready { return 404; }

    location = / {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://127.0.0.1:{{ app_port }};
    }

    location /items {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://127.0.0.1:{{ app_port }};
    }
}
